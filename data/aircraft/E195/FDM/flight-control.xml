                /systems/actuators/rudder/pcu[0]/active &gt; 0
                /systems/actuators/rudder/pcu[1]/active &gt; 0
            </test>
        </switch>

        <actuator>
            <input>fcs/rudder-sum</input>
            <rate_limit>fcs/rudder-rate-limit</rate_limit>
            <output>fcs/rudder-master</output>
        </actuator>-->

        <aerosurface_scale name="Rudder Control">
            <input>fcs/rudder-master</input>
            <range>
                <min> -0.530 </min>
                <max>  0.530 </max>
            </range>
            <output>fcs/rudder-pos-rad</output>
        </aerosurface_scale>

        <aerosurface_scale name="rudder normalization">
            <input>fcs/rudder-pos-rad</input>
            <domain>
                <min> -0.530 </min>
                <max>  0.530 </max>
            </domain>
            <range>
                <min> -1 </min>
                <max>  1 </max>
            </range>
            <output>fcs/rudder-pos-norm</output>
        </aerosurface_scale>

    </channel>

    <channel name="Slats">

        <!--Set slats according to http://www.smartcockpit.com/docs/Embraer_190-Flight_Controls.pdf page 4-->
        <fcs_function name="Slats Cmd">
            <function>
                <table>
                    <independentVar>/controls/flight/flaps</independentVar>
                    <tableData>
                        0.000   0
                        0.125  15
                        0.250  15
                        0.375  15
                        0.500  25
                        0.625  25
                        0.750  25
                    </tableData>
                </table>
            </function>
            <output>fcs/slat-cmd-int-deg</output>
        </fcs_function>

        <kinematic name="Slats Control">
            <input>fcs/slat-cmd-int-deg</input>
            <noscale/>
            <traverse>
                <setting>
                    <position>0.0</position>
                    <time>0.0000</time>
                </setting>
                <setting>
                    <position>15</position>
                    <time>2.0000</time>
                </setting>
                <setting>
                    <position>25</position>
                    <time>1.5000</time>
                </setting>
            </traverse>
            <output>fcs/slat-pos-deg</output>
        </kinematic>

        <aerosurface_scale name="slat normalization">
            <input>fcs/slat-pos-deg</input>
            <domain>
                <min>  0 </min>
                <max> 25 </max>
            </domain>
            <range>
                <min> 0 </min>
                <max> 1 </max>
            </range>
            <output>fcs/slat-pos-norm</output>
        </aerosurface_scale>

    </channel>




    <channel name="Flaps">


        <!-- Set flaps according to http://www.smartcockpit.com/docs/Embraer_190-Flight_Controls.pdf page 4-->
        <fcs_function name="Flaps Cmd">
            <function>
                <table>
                    <independentVar>/controls/flight/flaps</independentVar>
                    <tableData>
                        0.000   0
                        0.125   5
                        0.250  10
                        0.375  20
                        0.500  20
                        0.625  20
                        0.750  35
                    </tableData>
                </table>
            </function>
            <output>fcs/flap-cmd-int-deg</output>
        </fcs_function>

        <kinematic name="Flaps Control">
            <input>fcs/flap-cmd-int-deg</input>
            <noscale/>
            <traverse>
                <setting>
                    <position>0</position>
                    <time>0.0000</time>
                </setting>
                <setting>
                    <position>5</position>
                    <time>2.0000</time>
                </setting>
                <setting>
                    <position>10</position>
                    <time>2.0000</time>
                </setting>
                <setting>
                    <position>20</position>
                    <time>2.0000</time>
                </setting>
                <setting>
                    <position>35</position>
                    <time>3.0000</time>
                </setting>
            </traverse>
            <output>fcs/flap-pos-deg</output>
        </kinematic>

        <aerosurface_scale name="flap normalization">
            <input>fcs/flap-pos-deg</input>
            <domain>
                <min>  0 </min>
                <max> 35 </max>
            </domain>
            <range>
                <min> 0 </min>
                <max> 1 </max>
            </range>
            <output>fcs/flap-pos-norm</output>
        </aerosurface_scale>

    </channel>

