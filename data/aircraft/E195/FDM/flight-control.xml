<?xml version="1.0"?>

<flight_control name="FCS: E-Jet-Family">

    <property value="0">fcs/mfs1-pos-norm</property>
    <property value="0">fcs/mfs2-pos-norm</property>
    <property value="0">fcs/mfs3-pos-norm</property>
    <property value="0">fcs/mfs4-pos-norm</property>
    <property value="0">fcs/mfs5-pos-norm</property>
    <property value="0">fcs/mfs6-pos-norm</property>
    <property value="0">fcs/mfs7-pos-norm</property>
    <property value="0">fcs/mfs8-pos-norm</property>
    <property value="0">fcs/mfs9-pos-norm</property>
    <property value="0">fcs/mfs10-pos-norm</property>

    <property value="0">fcs/steer-nose-deg[0]</property>


<!--     <property>/systems/actuators/elevator/pcu[0]/active</property> -->
    <property value="1">/systems/actuators/elevator/pcu[0]/active</property>
    <property value="1">/systems/actuators/elevator/pcu[1]/active</property>
    <property value="1">/systems/actuators/elevator/pcu[2]/active</property>
    <property value="1">/systems/actuators/elevator/pcu[3]/active</property>

    <!-- Aileron / rudder PCUs — powered by default; HydraulicModule will override -->
    <property value="1">/systems/actuators/aileron/pcu[0]/active</property>
    <property value="1">/systems/actuators/aileron/pcu[1]/active</property>
    <property value="1">/systems/actuators/aileron/pcu[2]/active</property>
    <property value="1">/systems/actuators/aileron/pcu[3]/active</property>
    <property value="1">/systems/actuators/rudder/pcu[0]/active</property>
    <property value="1">/systems/actuators/rudder/pcu[1]/active</property>

    <!-- FBW elevator command — written by FlightDynamicsModule each frame -->
    <property value="0">/fcs/elevator-cmd-fbw</property>

    <!-- Yaw damper enable flag (0 = disabled; future yaw-damper module writes 1) -->
    <property value="0">fcs/yaw-damper-enable</property>

    <!-- aero-config/coefficients — originally set by FlightGear Nasal scripts.
         Values restored from commented-out hints in aerodynamics.xml.
         Coefficients that multiply a table (drag-alpha/mach/beta) use 1.0 (neutral).
         Cross-coupling terms (bank-*, yaw-elevator) use 0 until tuned. -->

    <!-- Lift coefficients (CLde, CLdhs) — 1.0 because aerodynamics.xml already has ×0.5 factor -->
    <property value="1">aero-config/coefficients/lift-elevator</property>
    <property value="1">aero-config/coefficients/lift-hstab</property>

    <!-- Drag coefficients — from commented-out hints in aerodynamics.xml -->
    <property value="0.01">aero-config/coefficients/drag-parasitic</property>
    <property value="1">aero-config/coefficients/drag-alpha</property>    <!-- table already scaled -->
    <property value="0.02">aero-config/coefficients/drag-induced</property>
    <property value="1">aero-config/coefficients/drag-mach</property>     <!-- table already scaled -->
    <property value="1">aero-config/coefficients/drag-beta</property>     <!-- table already scaled -->
    <property value="0.004">aero-config/coefficients/drag-flap</property>
    <property value="0.0015">aero-config/coefficients/drag-slat</property>
    <property value="0.004">aero-config/coefficients/drag-gear</property>
    <property value="0.003">aero-config/coefficients/drag-mfs</property>
    <property value="0.005">aero-config/coefficients/drag-elevator</property>
    <property value="0.005">aero-config/coefficients/drag-hstab</property>

    <!-- Cross-coupling moments — small; set to 0 until aerodynamic tuning -->
    <property value="0">aero-config/coefficients/bank-rudder</property>
    <property value="0">aero-config/coefficients/bank-elevator</property>
    <property value="0">aero-config/coefficients/yaw-elevator</property>

    <!-- Yaw damper gains -->
    <property value="1">aero-config/coefficients/yaw-damper-beta</property>
    <property value="1">aero-config/coefficients/yaw-damper-rate</property>

    <!-- Ground speed (FlightGear property; JSBSim does not auto-create before RunIC) -->
    <property value="0">/velocities/groundspeed-kt</property>

    <!-- Gear unit properties — created by ground_reactions but needed by FCS at load time -->
    <property value="0">gear/unit[0]/castered</property>
    <property value="0">gear/unit[0]/steering-angle-deg</property>


    <!-- Autopilot / autoflight — zero until AP module is implemented -->
    <property value="0">/it-autoflight/internal/aileron</property>
    <property value="0">/it-autoflight/internal/rudder</property>
    <property value="0">/autopilot/autobrake/output-brake</property>
    <property value="0">/autopilot/autobrake/engaged</property>

    <!-- FADEC throttle commands — written by FlightDynamicsModule each frame -->
    <property value="0">/fadec/throttle-cmd[0]</property>
    <property value="0">/fadec/throttle-cmd[1]</property>

    <!-- Hydraulic systems — pressurized by default; HydraulicModule will override -->
    <property value="1">/systems/hydraulic/system[0]/pressurized</property>
    <property value="1">/systems/hydraulic/system[1]/pressurized</property>
    <property value="3000">/systems/hydraulic/system[0]/pressure-psi</property>
    <property value="3000">/systems/hydraulic/system[1]/pressure-psi</property>
    <property value="1">/systems/hydraulic/system[0]/emergency-accumulator</property>
    <property value="1">/systems/hydraulic/system[1]/emergency-accumulator</property>

    <!-- MFS (spoiler) commands — written by FlightDynamicsModule each frame -->
    <property value="0">/fcs/mfs-left-outboard-cmd-norm</property>
    <property value="0">/fcs/mfs-left-inboard-cmd-norm</property>
    <property value="0">/fcs/mfs-right-outboard-cmd-norm</property>
    <property value="0">/fcs/mfs-right-inboard-cmd-norm</property>

    <!-- Flight controls — FlightGear inputs; FlightDynamicsModule writes these each frame -->
    <property value="0">/controls/flight/rudder</property>
    <property value="0">/controls/flight/flaps</property>

    <!-- Gear / brakes / tiller -->
    <property value="0">/controls/gear/brake-left</property>
    <property value="0">/controls/gear/brake-right</property>
    <property value="0">/controls/gear/brake-parking</property>
    <property value="0">/controls/gear/enable-tiller</property>
    <property value="0">/controls/gear/tiller-pushed</property>
    <property value="0">/controls/gear/tiller-cmd-norm</property>





    <property value="0">fcs/left-aileron-master</property>
    <property value="0">fcs/right-aileron-master</property>
    <property value="0">fcs/elevator-rh-master</property>
    <property value="0">fcs/elevator-lh-master</property>
    <property value="0">fcs/rudder-master</property>




    <!-- Ground services / autopush — not used in our sim -->
    <property value="0">/services/chocks</property>
    <property value="0">/sim/model/autopush/connected</property>
    <property value="0">/sim/model/autopush/autopush-cmd-norm</property>
    <property value="0">/options/controls/realistic-nose-wheel-steering</property>

    <channel name="Pitch">
        <fcs_function name="Elevator Unpowered">
            <function>
                <table>
                    <independentVar lookup="row">aero/qbar-psf</independentVar>
                    <tableData>
                         0 1
                         1 1
                        15 0.5
                        50 0.1
                    </tableData>
                </table>
            </function>
            <output>fcs/elevator-unpowered</output>
        </fcs_function>

       <!-- <switch>
            <output>fcs/elevator-lh-cmd-powered</output>
            <default value="fcs/elevator-unpowered" />
            <test logic="OR" value="fcs/elevator-cmd-fbw">
                /systems/actuators/elevator/pcu[0]/active &gt; 0
                /systems/actuators/elevator/pcu[1]/active &gt; 0
            </test>
        </switch>

        <actuator name="Elevator Master">
            <input>fcs/elevator-lh-cmd-powered</input>
            <rate_limit>2</rate_limit>
            <output>fcs/elevator-lh-master</output>
        </actuator>-->

        <fcs_function name="fbw/elevator/stall-prot/min">
            <function>
                <ifthen>
                    <and>
                        <eq>
                            <property>gear/unit[1]/WOW</property>
                            <value>0</value>
                        </eq>
                        <eq>
                            <property>gear/unit[2]/WOW</property>
                            <value>0</value>
                        </eq>
                    </and>

                    <table>
                        <independentVar lookup="row">aero/alpha-wing-rad</independentVar>
                        <tableData>
                            0.00   -1.0
                            0.11   -1.0
                            0.30    1.0
                        </tableData>
                    </table>

                    <value>-1.0</value>
                </ifthen>
            </function>
            <output>fbw/elevator/stall-prot/min</output>
        </fcs_function>

        <aerosurface_scale name="Elevator Control">
            <input>fcs/elevator-lh-master</input>
            <range>
                <min> -0.25 </min>
                <max>  0.25 </max>
            </range>
            <output>fcs/elevator-lh-pos-rad</output>
        </aerosurface_scale>

        <aerosurface_scale name="Elevator Normalization">
            <input>fcs/elevator-lh-pos-rad</input>
            <domain>
                <min> -0.25 </min>
                <max>  0.25 </max>
            </domain>
            <range>
                <min> -1 </min>
                <max>  1 </max>
            </range>
            <output>fcs/elevator-lh-pos-norm</output>
        </aerosurface_scale>

       <!-- <switch>
            <output>fcs/elevator-rh-cmd-powered</output>
            <default value="fcs/elevator-unpowered" />
            <test logic="OR" value="fcs/elevator-cmd-fbw">
                /systems/actuators/elevator/pcu[2]/active &gt; 0
                /systems/actuators/elevator/pcu[3]/active &gt; 0
            </test>
        </switch>

        <actuator name="Elevator Master">
            <input>fcs/elevator-rh-cmd-powered</input>
            <rate_limit>2</rate_limit>
            <output>fcs/elevator-rh-master</output>
        </actuator>-->

        <aerosurface_scale name="Elevator Control">
            <input>fcs/elevator-rh-master</input>
            <range>
                <min> -0.25 </min>
                <max>  0.25 </max>
            </range>
            <output>fcs/elevator-rh-pos-rad</output>
        </aerosurface_scale>

        <aerosurface_scale name="Elevator Normalization">
            <input>fcs/elevator-rh-pos-rad</input>
            <domain>
                <min> -0.25 </min>
                <max>  0.25 </max>
            </domain>
            <range>
                <min> -1 </min>
                <max>  1 </max>
            </range>
            <output>fcs/elevator-rh-pos-norm</output>
        </aerosurface_scale>


        <aerosurface_scale name="HStab Control">
            <input>fcs/pitch-trim-cmd-norm</input>
            <range>
                <min> -0.25 </min>
                <max>  0.25 </max>
            </range>
            <output>fcs/hstab-pos-rad</output>
        </aerosurface_scale>

        <aerosurface_scale name="HStab Normalization">
            <input>fcs/hstab-pos-rad</input>
            <domain>
                <min> -0.25 </min>
                <max>  0.25 </max>
            </domain>
            <range>
                <min> -1 </min>
                <max>  1 </max>
            </range>
            <output>fcs/hstab-pos-norm</output>
        </aerosurface_scale>

        <aerosurface_scale name="HStab Degrees">
            <input>fcs/hstab-pos-rad</input>
            <domain>
                <min> -0.25 </min>
                <max>  0.25 </max>
            </domain>
            <range>
                <min> -14.3239448782705 </min>
                <max>  14.3239448782705 </max>
            </range>
            <output>fcs/hstab-pos-deg</output>
        </aerosurface_scale>
    </channel>

    <channel name="Roll">
        <summer name="fcs/aileron-sum">
            <input>it-autoflight/internal/aileron</input>
            <output>fcs/aileron-sum</output>
        </summer>


        <summer name="Roll Trim Sum">
            <input>fcs/aileron-sum</input>
            <input>fcs/roll-trim-cmd-norm</input>
            <clipto>
                <min> -1 </min>
                <max>  1 </max>
            </clipto>
        </summer>

