                <table>
                    <independentVar lookup="row">aero/qbar-psf</independentVar>
                    <tableData>
                         0 1
                         1 1
                        15 0.5
                        50 0.1
                    </tableData>
                </table>
            </function>
            <output>fcs/aileron-unpowered</output>
        </fcs_function>

